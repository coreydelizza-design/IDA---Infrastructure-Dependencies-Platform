# IDA — environment configuration example. Copy to .env.local and adjust.
# No real secrets belong in this file or in the repository.

# Data mode: "local" (browser localStorage, default) or "supabase".
VITE_DATA_MODE=local

# Supabase mode only. Use the project URL and the public anon key.
# NEVER place a service-role key in the browser / any VITE_ variable.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
